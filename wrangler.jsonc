{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hohohocch-site",
  "main": "./functions/_worker.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "compatibility_date": "2026-05-23",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
